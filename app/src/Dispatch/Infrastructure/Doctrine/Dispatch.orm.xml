<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="App\Dispatch\Domain\Entity\Dispatch" table="dispatches">
        <id name="id" type="string" column="id" length="36">
            <generator strategy="NONE"/>
        </id>
        <many-to-one field="package" target-entity="App\Package\Domain\Entity\ShipmentPackage" fetch="LAZY">
            <join-column name="package_id" referenced-column-name="id" nullable="false" unique="true" on-delete="CASCADE" column-definition="varchar(36)"/>
        </many-to-one>
        <many-to-one field="courier" target-entity="App\Courier\Domain\Entity\Courier" fetch="LAZY">
            <join-column name="courier_id" referenced-column-name="id" nullable="true" on-delete="SET NULL" column-definition="varchar(36)"/>
        </many-to-one>
        <field name="status" type="string" length="20"/>
        <field name="referenceNumber" type="string" length="50" unique="true" column="reference_number"/>
        <field name="originAddress" type="string" length="500" column="origin_address"/>
        <field name="destinationAddress" type="string" length="500" column="destination_address"/>
        <field name="notes" type="string" length="500" nullable="true"/>
        <field name="assignedAt" type="datetime_immutable" column="assigned_at" nullable="true"/>
        <field name="pickedUpAt" type="datetime_immutable" column="picked_up_at" nullable="true"/>
        <field name="deliveredAt" type="datetime_immutable" column="delivered_at" nullable="true"/>
        <field name="createdAt" type="datetime_immutable" column="created_at"/>
        <field name="updatedAt" type="datetime_immutable" column="updated_at"/>
        <indexes>
            <index name="idx_dispatches_status_created_at" columns="status,created_at"/>
            <index name="idx_dispatches_courier_status" columns="courier_id,status"/>
        </indexes>
    </entity>
</doctrine-mapping>
